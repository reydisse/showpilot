{
	"name": "@showpilot/web",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "pnpm build && vite preview",
		"test": "vitest run",
		"deploy": "pnpm build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "prisma generate",
		"db:migrate:local": "wrangler d1 execute showpilot-db --local --file=prisma/migrations/0001_init.sql",
		"db:migrate:remote": "wrangler d1 execute showpilot-db --remote --file=prisma/migrations/0001_init.sql"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.13.8",
		"@prisma/adapter-d1": "^7.0.0",
		"@prisma/client": "^7.0.0",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "^0.7.0",
		"@tanstack/react-router": "^1.132.0",
		"@tanstack/react-router-devtools": "^1.132.0",
		"@tanstack/react-router-ssr-query": "^1.131.7",
		"@tanstack/react-start": "^1.132.0",
		"@tanstack/router-plugin": "^1.132.0",
		"better-auth": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.33.0",
		"lucide-react": "^0.545.0",
		"qrcode.react": "^4.2.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18"
	},
	"devDependencies": {
		"@tanstack/devtools-vite": "^0.3.11",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/node": "^22.19.13",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.0.4",
		"jsdom": "^27.0.0",
		"prisma": "^7.0.0",
		"shadcn": "^3.8.5",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5",
		"wrangler": "^4.69.0"
	}
}